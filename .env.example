# 좌표.to 환경변수 예제
# 사용법: 이 파일을 .env.local로 복사하고 실제 값을 채우세요.
#   cp .env.example .env.local
#
# 프로덕션은 Vercel 대시보드 > Settings > Environment Variables에서 설정.

# === Supabase ===
# Supabase 프로젝트 > Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # 서버 전용. 클라이언트 노출 금지.
SUPABASE_JWT_SECRET=""

# === PortOne 결제 ===
# PortOne 어드민(https://admin.portone.io) > 상점 관리 / 채널 관리에서 복사.
# 라이브 키는 사업자 인증 + PG 계약 완료 후 발급됨.
NEXT_PUBLIC_PORTONE_STORE_ID="store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
NEXT_PUBLIC_PORTONE_CHANNEL_KEY="channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"               # 카드 직접입력 (KPN/KCP/이니시스 등)
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_KAKAOPAY="channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"      # 카카오페이 정기결제 채널 (간편결제)
PORTONE_API_SECRET=""        # 서버 전용. /api/payment/* 라우트에서 사용.
PORTONE_WEBHOOK_SECRET=""    # 어드민에서 webhook endpoint 등록 후 발급됨.

# === 사업자 정보 (전자상거래법 표시 의무) ===
# footer, 약관, 결제 페이지에서 사용. 모두 NEXT_PUBLIC_ prefix — 어차피 공개되는 정보.
# 값이 비어 있으면 footer는 placeholder("등록 진행 중")로 표시되어 사이트는 깨지지 않음.
NEXT_PUBLIC_BUSINESS_NAME="좌표연구소"                       # 상호 (사업자등록증의 법인/상호명)
NEXT_PUBLIC_BUSINESS_REPRESENTATIVE="송민우"                  # 대표자 성명
NEXT_PUBLIC_BUSINESS_REGISTRATION_NUMBER="789-32-01893"      # 사업자등록번호 (000-00-00000)
NEXT_PUBLIC_BUSINESS_MAIL_ORDER_NUMBER=""                    # 통신판매업 신고번호 (2026-서울XX-XXXX) — 신고 진행 중
NEXT_PUBLIC_BUSINESS_ADDRESS="서울특별시 금천구 두산로5길 45(가산동)"  # 사업장 주소
NEXT_PUBLIC_BUSINESS_PHONE=""                                # 고객 지원 전화 (선택)
NEXT_PUBLIC_BUSINESS_EMAIL="support.vecto@gmail.com"         # 고객 지원 이메일
